# Student Buddy Backend — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/studentbuddy

# JWT secret for API tokens (use a strong random string in production)
JWT_SECRET=dev-secret-change-me-in-production

# JWT token expiration
JWT_EXPIRES_IN=7d

# Path to Firebase service account JSON (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Your Chrome extension ID (find at chrome://extensions after loading unpacked)
EXTENSION_ID=your-extension-id-here

# Server port
PORT=3001
