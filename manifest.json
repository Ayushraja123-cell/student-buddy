{
  "manifest_version": 3,
  "name": "Student Buddy",
  "version": "2.0.0",
  "description": "Your all-in-one AI-powered study companion — Pomodoro timer, flashcards, AI summarizer, focus mode, cloud sync, and more.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Student Buddy"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "notifications",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://accounts.google.com/*",
    "https://*.googleapis.com/*",
    "http://localhost:3001/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Student Buddy"
    }
  }
}
